using System;
class main 
{
    static void Main()
    {
        int first=int.MinValue;
        int second=int.MinValue;
        
        int [] arr={10,20,5,15};
        
        for(int i=0;i<arr.Length;i++)
        {
            if(first<arr[i])
            {
                second=first;
                first=arr[i];
            }
            else if(arr[i]>second && arr[i]!=first)
            {
                second=arr[i];
            }
        }
        Console.WriteLine(first+" "+second);
        
    }
}
