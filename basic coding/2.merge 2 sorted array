using System;
class main 
{
    static void Main()
    {
      
        
        int [] arr={1,3,5,7};
        int [] brr={2,4,6,8};
        int [] crr=new int[arr.Length+brr.Length];
        
        int i=0,j=0,k=0;
        
        while(i<arr.Length && j<brr.Length)
        {
            if(arr[i]<brr[j])
            {
                crr[k++]=arr[i++];
            }
            else
            {
                crr[k++]=brr[j++];
            }
        }
        while(i<arr.Length)
        {
            crr[k++]=arr[i++];
        }
        while(j<brr.Length)
        {
            crr[k++]=brr[j++];
        }
        
        foreach(int x in crr)
        {
            Console.Write(x+" ");
        }
        
    }
}
