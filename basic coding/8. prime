using System;
class main 
{
    static bool IsPrime(int a)
    {
        if(a==0 || a==1)
        {
            return false;
        }
        for(int i=2;i<=a/2;i++)
        {
            if(a%i==0)
            {
                return false;
            }
        }
        return true;
    }
    static void Main()
    {
        int a=7;
        if(IsPrime(a))
        {
            Console.WriteLine("prime");
        }
        else
        {
            Console.WriteLine("not prime");
        }
    }
}
