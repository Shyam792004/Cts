using System;
class main 
{
    static int gcd(int a,int b)
    {
        while(b!=0)
        {
            int temp=b;
            b=a%b;
            a=temp;
            
        }
        return a;
    }
    static void Main()
    {
      int a=12;
      int b=4;
      
      int gcdno=gcd(a,b);
      int lcm=(a*b)/gcdno;
      Console.WriteLine("gcd:"+gcdno+" "+"lcm: "+lcm);
        
    }
}
