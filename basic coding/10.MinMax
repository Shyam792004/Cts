using System;
class main 
{
   static void Main()
   {
       int [] arr={1,2,3,4,5};
       int min=int.MaxValue;
       int max=int.MinValue;
       for(int i=0;i<arr.Length;i++)
       {
           if(min>arr[i])
           {
               min=arr[i];
           }
           if(max<arr[i])
           {
               max=arr[i];
           }
       }
       Console.WriteLine(min+" "+max);
       
   }
}
