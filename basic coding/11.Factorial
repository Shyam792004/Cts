using System;
class main 
{
    static int Fact(int n)
    {
        if(n==1)
        {
            return 1;
        }
        return n*Fact(n-1);
    }
   static void Main()
   {
       int n=5;
       int fact=1;
       for(int i=1;i<=n;i++)
       {
           fact=fact*i;
       }
       
       int ans=Fact(n);
       Console.WriteLine(fact);
       Console.WriteLine(ans);
   }
}
